# === LLM 配置 ===
# OpenAI API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 或使用 DeepSeek API
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === 微信公众号配置 ===
# 获取方式：登录微信公众平台 -> 开发 -> 基本配置
WECHAT_APP_ID=wx...
WECHAT_APP_SECRET=your-app-secret

# 注意：
# 1. 需要将服务器 IP 添加到公众号后台的白名单
# 2. 订阅号每天可群发 1 次，服务号每月 4 次
# 3. 草稿箱功能无限制

# === Unsplash 图片服务（预留功能）===
# 获取方式：访问 https://unsplash.com/developers 注册开发者账号并创建应用
# 注意：
# 1. 免费版 API 限制：每小时 50 次请求，每天 5000 次
# 2. 使用图片需按要求署名（摄影师 + Unsplash）
UNSPLASH_ACCESS_KEY=your-access-key

# Cloudinary 图片托管（cloudinary-image-host 技能）
# 获取：https://cloudinary.com
# 限制：免费版每月 25 credits（约 25000 次转换或 25000 MB 存储/带宽）
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret